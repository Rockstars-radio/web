{
  "name": "rockstars-radio",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build:web": "expo export --platform web && node scripts/postbuild-web.js",
    "build:ios:testflight": "eas build --platform ios --profile production",
    "submit:ios:testflight": "eas submit --platform ios --latest"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "expo": "~54.0.33",
    "expo-audio": "~1.1.1",
    "expo-status-bar": "~3.0.9",
    "hls.js": "^1.6.15",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "eas-cli": "^18.4.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
