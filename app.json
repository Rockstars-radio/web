{
  "expo": {
    "name": "Rockstars Radio",
    "slug": "rockstars-radio",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/rockstars-isotipo.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/rockstars-logo-white.png",
      "resizeMode": "contain",
      "backgroundColor": "#050505"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "co.com.rockstars.rockstarsradio",
      "buildNumber": "1",
      "infoPlist": {
        "UIBackgroundModes": [
          "audio"
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "co.com.rockstars.rockstarsradio",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/rockstars-isotipo.png",
        "backgroundColor": "#050505"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "favicon": "./assets/rockstars-isotipo.png"
    },
    "plugins": [
      [
        "expo-audio",
        {
          "enableBackgroundPlayback": true,
          "enableBackgroundRecording": false,
          "microphonePermission": false,
          "recordAudioAndroid": false
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "e6fee20d-adcd-44d7-b201-a8c47435c1e9"
      }
    }
  }
}
