{
  "expo": {
    "name": "Rockstars Radio",
    "slug": "rockstars-radio",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/rockstars-logo-white.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/rockstars-logo-white.png",
      "resizeMode": "contain",
      "backgroundColor": "#050505"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/rockstars-logo-white.png",
        "backgroundColor": "#050505"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/rockstars-logo-white.png"
    },
    "plugins": [
      [
        "expo-audio",
        {
          "enableBackgroundPlayback": true,
          "enableBackgroundRecording": false,
          "microphonePermission": false,
          "recordAudioAndroid": false
        }
      ]
    ]
  }
}
